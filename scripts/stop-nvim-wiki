#!/bin/sh
set -eu

SOCK="${XDG_RUNTIME_DIR:-/tmp}/nvim-wiki.sock"
LAUNCHER="$HOME/.local/bin/launch-nvim-wiki"

notify() {
    notify-send -a "nvim wiki script" "$1"
}

if [ ! -S "$SOCK" ]; then
    notify "No server socket found."
    exit 0
fi

nvim --server "$SOCK" --remote-send '<C-\><C-N>:qa<CR>'

sleep 0.2

if [ -S "$SOCK" ]; then
    notify "Unsaved changes. Opening UI to review them."

    ghostty -e "$LAUNCHER"

    if [ ! -S "$SOCK" ]; then
        notify "Server stopped."
        exit 0
    fi

    notify "Review done. Run stop-nvim-wiki again to stop the server."
    exit 0
fi

notify "Server stopped."
